#include<stdio.h>
#include<unistd.h>
#include<sys/types.h>
#include<sys/wait.h>
int main() {
   int fd[2];
   pid_t pid;
   int num[2];
   pipe(fd);
   pid=fork();
   if ( pid > 0 ) {
      close(fd[1]);
      read(fd[0],num,sizeof(num));
      int a=num[0];
      int b=num[1];
      int temp;
      while(b!=0) {
	 temp=b;
	 b=a%b;
	 a=temp;
      }
      printf("P1(Parent) \n");
      printf("Number Received: %d   %d",num[0],num[1]);
      printf("\nGCD: %d\n", a);
      close(fd[0]);
      wait(NULL);
   }
   else if (pid==0) {
      close(fd[0]);
      printf("P2(CHILD)\n");
      printf("Enter Two Numbers: ");
      scanf("%d %d",&num[0],&num[1]);
      write(fd[1],num,sizeof(num));
      close(fd[1]);
   }
   return 0;
}

